generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Profile {
  id                Int      @id @default(1)
  name              String   @default("Gabriel")
  age               Int      @default(30)
  proteinGoal       Int      @default(120)
  weeklyProteinGoal Int      @default(0)
  fiberGoal         Int      @default(25)
  unit              String   @default("lbs")
  startWaist        Float?
  startHips         Float?
  startChest        Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Phase {
  id           Int             @id @default(autoincrement())
  name         String
  description  String?
  icon         String          @default("🧪")
  color        String          @default("#E8A838")
  startDate    DateTime
  endDate      DateTime
  duration     Int             @default(14)
  active       Boolean         @default(false)
  trackProtein Boolean         @default(true)
  sortOrder    Int             @default(0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  logs         DailyLog[]
  questions    PhaseQuestion[]
}

model PhaseQuestion {
  id        Int    @id @default(autoincrement())
  phaseId   Int
  phase     Phase  @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  label     String
  type      String
  key       String
  sortOrder Int    @default(0)
}

model DailyLog {
  id              Int              @id @default(autoincrement())
  date            String           @unique
  phaseId         Int?
  phase           Phase?           @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  proteinPriority Boolean?
  fiberGrams      Float?
  note            String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  proteinEntries  ProteinEntry[]
  questionAnswers QuestionAnswer[]
}

model ProteinEntry {
  id        Int      @id @default(autoincrement())
  logId     Int
  log       DailyLog @relation(fields: [logId], references: [id], onDelete: Cascade)
  sourceKey String
  quantity  Float
}

model QuestionAnswer {
  id          Int      @id @default(autoincrement())
  logId       Int
  log         DailyLog @relation(fields: [logId], references: [id], onDelete: Cascade)
  questionKey String
  value       String
}

model Checkpoint {
  id        Int      @id @default(autoincrement())
  date      String
  waist     Float?
  hips      Float?
  chest     Float?
  note      String?
  createdAt DateTime @default(now())
}

model ProteinSource {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  label     String
  protein   Float
  unit      String
  emoji     String
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}
